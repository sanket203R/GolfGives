# ============================================
# GOLFGIVES ENVIRONMENT VARIABLES
# ============================================
# Copy this file and rename to .env in both:
#   - backend/.env
#   - golfcharity/.env
#   - .env (root, if needed)
# ============================================

# ================================
# DATABASE CONFIGURATION
# ================================
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/golf_charity?retryWrites=true&w=majority

# ================================
# AUTHENTICATION & SECURITY
# ================================
# JWT secret for signing authentication tokens (minimum 32 chars)
JWT_SECRET=YOUR_STRONG_SECRET_KEY_HERE_MINIMUM_32_CHARS

# ================================
# STRIPE PAYMENT PROCESSING
# ================================
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXX
STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_test_XXXXXXXXXXXX

# ================================
# EMAIL SERVICE (SendGrid)
# ================================
SENDGRID_API_KEY=SG.XXXXXXXXXXXX
SENDGRID_FROM_EMAIL=noreply@golfgives.com

# ================================
# SMS SERVICE (Twilio) - Optional
# ================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890

# ================================
# IMAGE HOSTING (Cloudinary)
# ================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ================================
# SERVER CONFIGURATION
# ================================
PORT=5000
NODE_ENV=development

# ================================
# FRONTEND CONFIGURATION
# ================================
# Used by React app in golfcharity/
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_STRIPE_PUBLIC_KEY=pk_test_XXXXXXXXXXXX

# ================================
# URL CONFIGURATION
# ================================
# Used for CORS, redirects, webhooks
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000
